Algoritmo "Area do pentagono"
// Disciplina   : [Lógica de Programaçăo com VisualG]
// Professor   : Jailson Costa dos Santos
// Descriçăo   : cálculo automatizado da area de um pentágono
// Autor(a)    : Beatriz Lacerda Rodrigues
// Data atual  : 27/03/2026
Var
// Seçăo de Declaraçőes das variáveis
lado: real
altura: real
resultado: real


Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc...
escreva("Digite o valor do lado do pentágono")
leia(lado)
escreva("Digite o valor da altura do pentágono")
leia(altura)
resultado<- (lado * altura * 5)
// 5 pois, o pentágono possui 5 lados)
escreva("O resultado da área do pentágono é:", resultado)



Fimalgoritmo